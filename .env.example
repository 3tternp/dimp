# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Domain Impersonation Monitoring Platform"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dimp:dimp_pass@db:5432/dimp
DATABASE_URL_SYNC=postgresql+psycopg2://dimp:dimp_pass@db:5432/dimp

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Auth ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Scanning ───────────────────────────────────────────────────────────────────
SCREENSHOT_DIR=/app/data/screenshots
REPORT_DIR=/app/data/reports
MAX_CONCURRENT_SCANS=10
HTTP_TIMEOUT=15
HTTP_USER_AGENT="DIMP-Scanner/1.0 (security research)"

# ── Threat intelligence feeds (optional) ─────────────────────────────────────
URLSCAN_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=

# ── Alerting ───────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@yourdomain.com

SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
SIEM_WEBHOOK_URL=

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
